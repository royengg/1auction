# ═══════════════════════════════════════════════════════════════════════════
# 1auction — Production Environment Variables
# Copy this file to `.env` (root) and fill the values for your deployment.
# In Coolify, set these as environment variables in the service settings.
# ═══════════════════════════════════════════════════════════════════════════

# ── Database (Neon PostgreSQL) ──────────────────────────────────────────────
# Use the pooled connection string from Neon dashboard.
# Must include ?sslmode=require for Neon.
DATABASE_URL="postgresql://user:password@ep-host.neon.tech/dbname?sslmode=require"

# ── BetterAuth (web app only) ───────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-32-byte-random-string"
# The public URL of your web app (e.g. https://auction.example.com)
BETTER_AUTH_URL="https://your-domain.com"

# ── JWT shared secret ───────────────────────────────────────────────────────
# MUST be identical on web app and socket server.
# Generate with: openssl rand -base64 32
JWT_SECRET="replace-with-another-32-byte-random-string"

# ── Redis ───────────────────────────────────────────────────────────────────
# Inside docker-compose, use the service name. For external Redis, use the URL.
REDIS_URL="redis://redis:6379"

# ── Socket.IO server ────────────────────────────────────────────────────────
# Port the socket server listens on inside the container.
SOCKET_SERVER_PORT="3001"
# URL the browser uses to connect to the socket server (public-facing).
# If using a subdomain: https://ws.your-domain.com
# If using same domain with path: https://your-domain.com (requires reverse proxy)
NEXT_PUBLIC_SOCKET_URL="https://ws.your-domain.com"
# URL the web app uses to reach the socket server server-side (inside Docker).
SOCKET_SERVER_INTERNAL_URL="http://socket-server:3001"
# Origin the socket server allows for CORS (the web app's public URL).
WEB_ORIGIN="https://your-domain.com"
