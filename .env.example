# ──────────────────────────────────────────────────────────────────────────
# 1auction — environment variables
# Copy this file to `.env` (root) and fill the values.
# Per-app overrides can also live in apps/web/.env.local
# ──────────────────────────────────────────────────────────────────────────

# Database (Neon PostgreSQL 17). Use the pooled connection string in production.
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# BetterAuth (Next.js app only)
BETTER_AUTH_SECRET="generate-a-long-random-string-here"
BETTER_AUTH_URL="http://localhost:3000"

# JWT shared secret — MUST be identical on the web app and socket server.
# Used by the web app to sign a short-lived token the socket server verifies.
# Generate with: `openssl rand -base64 32`
JWT_SECRET="generate-another-long-random-string-here"

# Redis (local self-host). Use `redis://redis:6379` inside docker-compose.
REDIS_URL="redis://localhost:6379"

# Socket.io server
SOCKET_SERVER_PORT="3001"
# URL the web app uses to reach the socket server from the browser.
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"
# URL the web app uses to reach the socket server from server-side code
# (e.g. when broadcasting via Redis pub/sub). Inside docker-compose:
#   http://socket-server:3001
SOCKET_SERVER_INTERNAL_URL="http://localhost:3001"
# Origin the socket server allows for CORS (the Next.js app origin).
WEB_ORIGIN="http://localhost:3000"

# Deployment (Coolify). Override these in production:
#   NEXT_PUBLIC_SOCKET_URL=https://ws.your-domain.tld
#   WEB_ORIGIN=https://your-domain.tld
#   BETTER_AUTH_URL=https://your-domain.tld